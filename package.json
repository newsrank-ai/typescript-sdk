{
  "name": "@newsrank/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the NewsRank AI API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "newsrank",
    "news",
    "api",
    "sdk",
    "typescript",
    "articles",
    "stories",
    "entities",
    "search"
  ],
  "author": "NewsRank AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newsrank-ai/typescript-sdk.git"
  },
  "homepage": "https://newsrank.ai/docs",
  "bugs": {
    "url": "https://github.com/newsrank-ai/typescript-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
